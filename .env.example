# Required: Your Google Gemini API key
# Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-api-key-here

# Optional: Override defaults (uncomment to use)
# OPENREEL_GEMINI_MODEL=gemini-2.5-flash       # gemini-2.5-flash | gemini-2.5-pro | gemini-2.0-flash-lite
# OPENREEL_ANALYSIS_MODE=fast                   # fast (~2.5h/chunk, cheaper) | detailed (~52min/chunk)
# OPENREEL_TARGET_CLIPS_PER_HOUR=2.5
# OPENREEL_MIN_CLIP_SECONDS=15
# OPENREEL_MARGIN_SECONDS=3.0
# OPENREEL_ACCURATE_CUTS=false
# OPENREEL_ANALYSIS_FPS=2
# OPENREEL_DOWNSCALE_FOR_ANALYSIS=false

# Optional: For auto-captions with OpenAI Whisper API (instead of local model)
# OPENREEL_OPENAI_API_KEY=sk-...

# Optional: For speaker diarization (requires pyannote.audio)
# OPENREEL_HF_TOKEN=hf_...
